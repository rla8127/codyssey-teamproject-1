    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// ⭐ 원하는 키워드 미리 정의 (여기서 수정하면 돼!)\nconst targetKeywords = [\n  'AI', '인공지능', 'LLM', 'ChatGPT', '챗GPT',\n  '딥러닝', '머신러닝', '생성형', '클로드', 'Claude',\n  '반도체', '엔비디아', 'GPU', 'OpenAI', '구글',\n  '챗봇', '자율주행', '로봇', '데이터센터', 'GPT'\n];\n\n// 각 기사에서 키워드 몇 개 포함되는지 카운트\nconst scoredItems = items.map(item => {\n  const title = item.json.title || '';\n  const content = item.json.contentSnippet || '';\n  const text = title + ' ' + content;\n  \n  // 포함된 키워드 목록\n  const matchedKeywords = targetKeywords.filter(kw => \n    text.includes(kw)\n  );\n  \n  return {\n    ...item.json,\n    matchedKeywords: matchedKeywords,\n    score: matchedKeywords.length  // 키워드 많이 포함될수록 높은 점수\n  };\n});\n\n// AI 관련 기사만 필터링 (키워드 1개 이상 포함)\nconst aiItems = scoredItems.filter(item => item.score > 0);\n\nif (aiItems.length === 0) {\n  // AI 관련 기사 없으면 전체에서 첫 번째\n  return [{ json: { ...items[0].json, matchedKeywords: [], score: 0, topKeyword: '없음' } }];\n}\n\n// 점수 높은 순으로 정렬 → 1개 선택\naiItems.sort((a, b) => b.score - a.score);\nconst selected = aiItems[0];\n\nreturn [{\n  json: {\n    ...selected,\n    topKeyword: selected.matchedKeywords[0] || '없음'\n  }\n}];"
      },
